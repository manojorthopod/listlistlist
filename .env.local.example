# ─── Clerk ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Get from Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your-clerk-webhook-secret

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── UploadThing ─────────────────────────────────────────────────────────────
# Get from https://uploadthing.com/dashboard → your app → API Keys
UPLOADTHING_TOKEN=your-uploadthing-token

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Get from Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Create these prices in Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_STARTER_MONTHLY_PRICE_ID=price_your-starter-monthly-price-id
NEXT_PUBLIC_STRIPE_STARTER_ANNUAL_PRICE_ID=price_your-starter-annual-price-id
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-monthly-price-id
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=price_your-pro-annual-price-id
NEXT_PUBLIC_STRIPE_TOPUP_STARTER_PRICE_ID=price_your-topup-starter-price-id
NEXT_PUBLIC_STRIPE_TOPUP_GROWTH_PRICE_ID=price_your-topup-growth-price-id
NEXT_PUBLIC_STRIPE_TOPUP_SCALE_PRICE_ID=price_your-topup-scale-price-id

# ─── Resend ───────────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# ─── Demo ─────────────────────────────────────────────────────────────────────
# Max number of demo generations allowed per day across all visitors
DEMO_DAILY_QUOTA=50

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-min-32-chars
